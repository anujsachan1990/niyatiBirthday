# Copy to .env for local builds, or set these in Netlify/Vercel dashboard.
# Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Public site URL for Open Graph share previews (optional locally; Netlify sets URL automatically)
SITE_URL=https://your-site.example.com
